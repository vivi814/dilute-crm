# ShopLine 設定
SL_DOMAIN=yourstore.shoplineapp.com
SL_TOKEN=sl_live_xxxxxxxxxxxxxxxx
SL_WEBHOOK_SECRET=your_webhook_secret

# 伺服器設定
PORT=3001

# 財務報表第二層密碼（只有拿到這組密碼的人能看財報）
FINANCE_ACCESS_CODE=change_me
# 用來簽章財報登入 cookie 的密鑰，跟 FINANCE_ACCESS_CODE 分開、不要用同一組值
FINANCE_COOKIE_SECRET=change_me_too

# GitHub 資料持久化（讓資料在伺服器重啟後不消失）
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxx
GITHUB_REPO=vivi814/dilute-crm
